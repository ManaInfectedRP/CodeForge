generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
}

enum CourseStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ChallengeLanguage {
  PYTHON
  JAVASCRIPT
  TYPESCRIPT
}

enum AchievementMetric {
  XP
  STREAK
  LESSONS_COMPLETED
  QUIZZES_PASSED
  CHALLENGES_SOLVED
}

enum ChallengeStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

model User {
  id                 String           @id @default(cuid())
  username           String           @unique
  email              String           @unique
  passwordHash       String
  role               Role             @default(STUDENT)
  avatarUrl          String?
  bio                String?
  xp                 Int              @default(0)
  streak             Int              @default(0)
  lastActiveAt       DateTime?
  createdAt          DateTime         @default(now())
  emailVerified      Boolean          @default(false)
  emailVerifyToken   String?          @unique
  emailVerifyExpires DateTime?
  bannedAt           DateTime?
  chatBlockedAt      DateTime?
  certificates       Certificate[]
  paths          UserPath[]
  enrollments    Enrollment[]
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  coursesTaught  Course[]         @relation("InstructorCourses")
  challengeSubmissions ChallengeSubmission[]
  achievements         UserAchievement[]
  challengesAuthored   Challenge[]           @relation("InstructorChallenges")
  chatMessages         ChatMessage[]
  projectSubmissions   ProjectSubmission[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  room      String
  userId    String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([room, createdAt])
}

model LearningPath {
  id             String     @id @default(cuid())
  slug           String     @unique
  name           String
  icon           String
  difficulty     Int
  estimatedHours Int
  projectCount   Int        @default(0)
  description    String
  courses        Course[]
  users          UserPath[]
}

model UserPath {
  userId    String
  pathId    String
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@id([userId, pathId])
}

model Course {
  id           String       @id @default(cuid())
  title        String
  description  String
  status       CourseStatus @default(DRAFT)
  reviewNote   String?
  pathId       String
  instructorId String
  createdAt    DateTime     @default(now())
  path         LearningPath @relation(fields: [pathId], references: [id])
  instructor   User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  lessons      Lesson[]
  enrollments  Enrollment[]
  certificates Certificate[]
}

model Certificate {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  verificationCode String   @unique
  issuedAt         DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Lesson {
  id                 String              @id @default(cuid())
  courseId           String
  title              String
  order              Int
  videoUrl           String?
  content            String
  requiresSubmission Boolean             @default(false)
  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz               Quiz?
  progress           LessonProgress[]
  submissions        ProjectSubmission[]

  @@unique([courseId, order])
}

model ProjectSubmission {
  id            String           @id @default(cuid())
  lessonId      String
  userId        String
  submissionUrl String
  status        SubmissionStatus @default(PENDING)
  feedback      String?
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?
  lesson        Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
}

model Quiz {
  id           String        @id @default(cuid())
  lessonId     String        @unique
  title        String
  passingScore Int           @default(70)
  lesson       Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]
}

model Question {
  id      String       @id @default(cuid())
  quizId  String
  type    QuestionType
  prompt  String
  options String[]
  answer  String
  order   Int
  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, order])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int
  passed    Boolean
  answers   Json
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Enrollment {
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([userId, courseId])
}

model LessonProgress {
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([userId, lessonId])
}

model Challenge {
  id           String                @id @default(cuid())
  slug         String                @unique
  title        String
  difficulty   ChallengeDifficulty
  languages    ChallengeLanguage[]
  prompt       String
  entryPoint   String
  starterCode  Json
  order        Int                   @default(0)
  status       ChallengeStatus       @default(DRAFT)
  reviewNote   String?
  instructorId String?
  createdAt    DateTime              @default(now())
  instructor   User?                 @relation("InstructorChallenges", fields: [instructorId], references: [id])
  testCases    ChallengeTestCase[]
  submissions  ChallengeSubmission[]
}

model ChallengeTestCase {
  id             String    @id @default(cuid())
  challengeId    String
  input          Json
  expectedOutput Json
  isHidden       Boolean   @default(true)
  order          Int
  challenge      Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, order])
}

model ChallengeSubmission {
  id          String            @id @default(cuid())
  challengeId String
  userId      String
  language    ChallengeLanguage
  passed      Boolean
  testsPassed Int
  testsTotal  Int
  results     Json
  createdAt   DateTime          @default(now())
  challenge   Challenge         @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([challengeId, userId])
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String
  icon        String
  metric      AchievementMetric
  threshold   Int
  unlocks     UserAchievement[]
}

model UserAchievement {
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
}

model PageViewCount {
  path      String   @id
  views     Int      @default(0)
  updatedAt DateTime @updatedAt
}
