DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kodstigen?schema=public"
JWT_SECRET="change-me"
PORT=4000

# Public URL used in verification-email links and certificate QR codes
APP_URL="http://localhost:5173"

# SMTP for verification emails, leave unset to log the links to the console instead
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=secret
# EMAIL_FROM="Kodstigen <no-reply@example.com>"

# Optional override for where lesson-video uploads are stored
# UPLOADS_DIR=/var/data/uploads

# GitHub OAuth ("Sign in with GitHub"), leave unset to disable it. Register an OAuth App at
# https://github.com/settings/developers with callback URL {APP_URL}/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
